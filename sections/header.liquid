{% comment %}
  Fresh N Delight Header
  - Shopify navigation menu
  - Shopify logo setting
  - Shop mega menu from selected collection
  - First 4 products automatically shown
  - Shop All links to selected collection
  - Desktop hover mega menu
  - Shopify search, account and cart routes
{% endcomment %}

<style>
  #FreshHeader-{{ section.id }} {
    --header-bg: {{ section.settings.header_bg }};
    --text-color: {{ section.settings.text_color }};
    --primary-color: {{ section.settings.primary_color }};
  }

  #FreshHeader-{{ section.id }} *,
  #FreshHeader-{{ section.id }} *::before,
  #FreshHeader-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #FreshHeader-{{ section.id }} {
    width: 100%;
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  #FreshHeader-{{ section.id }} .fresh-header {
    min-height: 80px;
    padding: 16px 40px;
    background: var(--header-bg);
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: relative;
    box-shadow: 0 1px 3px rgba(0,0,0,.06);
  }

  /* LOGO */
  #FreshHeader-{{ section.id }} .fresh-logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    z-index: 2;
  }

  #FreshHeader-{{ section.id }} .fresh-logo img {
    display: block;
    width: {{ section.settings.logo_width }}px;
    max-width: 100%;
    height: auto;
  }

  #FreshHeader-{{ section.id }} .fresh-logo-text {
    margin: 0;
    color: var(--primary-color);
    font-size: 28px;
    font-weight: 800;
    letter-spacing: -1px;
  }

  /* DESKTOP NAV */
  #FreshHeader-{{ section.id }} .fresh-desktop-nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  #FreshHeader-{{ section.id }} .fresh-nav-link {
    height: 1.2em;
    line-height: 1.2em;
    overflow: hidden;
    position: relative;
    display: inline-flex;
    flex-direction: column;
    color: var(--text-color);
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
  }

  #FreshHeader-{{ section.id }} .fresh-nav-text {
    display: block;
    transition: transform .35s cubic-bezier(.76,0,.24,1);
  }

  #FreshHeader-{{ section.id }} .fresh-nav-duplicate {
    position: absolute;
    top: 100%;
    left: 0;
    color: var(--primary-color);
  }

  {% comment %} #FreshHeader-{{ section.id }} .fresh-nav-link:hover .fresh-nav-text {
    transform: translateY(-100%);
  }  {% endcomment %}

  /* SHOP IS A MEGA-MENU TRIGGER, NOT A REDIRECT LINK */
 #FreshHeader-{{ section.id }} .fresh-shop-trigger {
  padding: 0;
  border: 0;
  background: transparent;
  color: var(--text-color);
  cursor: pointer;

  font-family: inherit;
  font-size: 15px;
  font-weight: 600;
  line-height: 1.2em;

  appearance: none;
  -webkit-appearance: none;
}

  /* SHOP MEGA MENU */
  #FreshHeader-{{ section.id }} .fresh-mega-item {
    position: static;
  }

  #FreshHeader-{{ section.id }} .fresh-mega-menu {
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    padding: 30px 40px 25px;
    background: #fff;
    border-top: 1px solid #eee;
    box-shadow: 0 15px 30px rgba(0,0,0,.08);
    display: none;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 20px;
    z-index: 999;
  }

  #FreshHeader-{{ section.id }} .fresh-mega-item:hover .fresh-mega-menu,
  #FreshHeader-{{ section.id }} .fresh-mega-item:focus-within .fresh-mega-menu,
  #FreshHeader-{{ section.id }} .fresh-mega-item.is-open .fresh-mega-menu {
    display: grid;
    animation: freshMegaOpen .35s ease;
  }

  {% comment %} #FreshHeader-{{ section.id }} .fresh-mega-item:hover > .fresh-nav-link .fresh-nav-text {
    color: var(--primary-color);
  } {% endcomment %}


  #FreshHeader-{{ section.id }} .fresh-shop-trigger {
  border: 0;
  background: transparent;
  cursor: pointer;
  font-family: inherit;
  font-size: 15px;
  font-weight: 600;
  appearance: none;
  -webkit-appearance: none;
}

#FreshHeader-{{ section.id }} .fresh-shop-trigger:hover,
#FreshHeader-{{ section.id }} .fresh-mega-item:hover .fresh-shop-trigger,
#FreshHeader-{{ section.id }} .fresh-mega-item.is-open .fresh-shop-trigger {
  background: #000;
  color: #fff;
}

#FreshHeader-{{ section.id }} .fresh-nav-duplicate {
  display: none;
}

#FreshHeader-{{ section.id }} .fresh-nav-link {
  position: relative;
  display: inline-flex;
  align-items: center;
  justify-content: center;

  height: auto;
  padding: 10px 16px;
  border-radius: 20px;
  overflow: hidden;

  color: var(--text-color);
  background: transparent;
  text-decoration: none;

  font-size: 15px;
  font-weight: 600;
  line-height: 1.2;

  transition:
    background-color 0.3s ease,
    color 0.3s ease,
    transform 0.3s ease;
}

#FreshHeader-{{ section.id }} .fresh-nav-link:hover {
  background: #000;
  color: #fff;
  transform: translateY(-2px);
}

#FreshHeader-{{ section.id }} .fresh-nav-text {
  display: block;
  color: inherit;
}







  @keyframes freshMegaOpen {
    from { opacity: 0; transform: translateY(-15px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* PRODUCT CARD */
  #FreshHeader-{{ section.id }} .fresh-product-card {
    position: relative;
    width: 100%;
    height: 400px;
    overflow: hidden;
    border-radius: 12px;
    text-decoration: none;
    color: #fff;
    background: #eee;
  }

  #FreshHeader-{{ section.id }} .fresh-product-card img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .6s cubic-bezier(.76,0,.24,1);
  }

  #FreshHeader-{{ section.id }} .fresh-product-card:hover img {
    transform: scale(1.08);
  }

  #FreshHeader-{{ section.id }} .fresh-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,.75) 0%, rgba(0,0,0,.2) 40%, transparent 65%);
    z-index: 1;
  }

  #FreshHeader-{{ section.id }} .fresh-product-content {
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    padding: 25px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    z-index: 2;
  }

  #FreshHeader-{{ section.id }} .fresh-product-content h3 {
    margin: 0 0 7px;
    color: #fff;
    font-size: 24px;
    font-weight: 700;
    line-height: 1.1;
  }

  #FreshHeader-{{ section.id }} .fresh-product-content p {
    margin: 0;
    color: rgba(255,255,255,.8);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  #FreshHeader-{{ section.id }} .fresh-arrow {
    width: 35px;
    height: 35px;
    flex-shrink: 0;
    border-radius: 50%;
    background: #fff;
    color: #000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transform: translateX(-15px);
    transition: opacity .3s ease, transform .3s ease;
  }

  #FreshHeader-{{ section.id }} .fresh-product-card:hover .fresh-arrow {
    opacity: 1;
    transform: translateX(0);
  }

  #FreshHeader-{{ section.id }} .fresh-mega-footer {
    grid-column: 1 / -1;
    text-align: center;
    padding-top: 10px;
  }

  #FreshHeader-{{ section.id }} .fresh-mega-footer a {
    color: var(--text-color);
    font-size: 16px;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  /* ICONS */
  #FreshHeader-{{ section.id }} .fresh-icons {
    display: flex;
    align-items: center;
    gap: 20px;
    z-index: 2;
  }

  #FreshHeader-{{ section.id }} .fresh-icon {
    color: var(--text-color);
    display: flex;
    text-decoration: none;
    transition: transform .2s ease, opacity .2s ease;
  }

  #FreshHeader-{{ section.id }} .fresh-icon:hover {
    opacity: .7;
    transform: scale(1.05);
  }

  #FreshHeader-{{ section.id }} .fresh-icon svg,
  #FreshHeader-{{ section.id }} .fresh-menu-toggle svg {
    width: 22px;
    height: 22px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* MOBILE */
  #FreshHeader-{{ section.id }} .fresh-mobile-menu {
    display: none;
  }

  #FreshHeader-{{ section.id }} .fresh-menu-toggle {
    list-style: none;
    cursor: pointer;
    display: flex;
    color: var(--text-color);
  }

  #FreshHeader-{{ section.id }} summary::-webkit-details-marker {
    display: none;
  }

  /* MOBILE FULL DRAWER */
  #FreshHeader-{{ section.id }} .fresh-mobile-nav {
    position: fixed;
    top: 115px; 
    left: 0;
    width: 100%;
    height: calc(100dvh - 70px);
    padding: 12px 22px 32px;
    background: #fff;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-y;
    box-shadow: 0 12px 30px rgba(0,0,0,.08);
    z-index: 998;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-nav > a,
  #FreshHeader-{{ section.id }} .fresh-mobile-shop > summary {
    min-height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--text-color);
    text-decoration: none;
    font-size: 18px;
    font-weight: 600;
    border-bottom: 1px solid #eee;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-shop {
    border-bottom: 1px solid #eee;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-shop > summary {
    list-style: none;
    cursor: pointer;
    border-bottom: 0;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-plus {
    width: 28px;
    height: 28px;
    position: relative;
    flex: 0 0 28px;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-plus::before,
  #FreshHeader-{{ section.id }} .fresh-mobile-plus::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 14px;
    height: 1.5px;
    background: currentColor;
    transform: translate(-50%, -50%);
    transition: transform .25s ease;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-plus::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-shop[open] .fresh-mobile-plus::after {
    transform: translate(-50%, -50%) rotate(0deg);
  }

  /* MOBILE SHOP - IMAGE CARDS + PRODUCT NAMES */
  #FreshHeader-{{ section.id }} .fresh-mobile-shop-products {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 14px;
    padding: 12px 0 18px;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-product-card {
    display: block;
    min-width: 0;
    padding: 0;
    color: var(--text-color);
    text-decoration: none;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-product-image-wrap {
    width: 100%;
    aspect-ratio: 1 / 1.15;
    overflow: hidden;
    border-radius: 12px;
    background: #f3f3f3;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-product-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform .4s ease;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-product-card:active .fresh-mobile-product-image {
    transform: scale(.98);
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-product-title {
    display: block;
    margin-top: 9px;
    color: var(--text-color);
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-product-subtitle {
    display: block;
    margin-top: 3px;
    font-size: 11px;
    font-weight: 400;
    opacity: .6;
    text-transform: uppercase;
    letter-spacing: .5px;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-shop-all {
    grid-column: 1 / -1;
    display: inline-block;
    justify-self: center;
    margin-top: 4px;
    padding: 4px 0;
    color: var(--text-color);
    font-size: 15px;
    font-weight: 700;
    text-decoration: underline;
    text-underline-offset: 5px;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-bottom {
    margin-top: 28px;
    padding-top: 18px;
    border-top: 1px solid #eee;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-login {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 0;
    color: var(--text-color);
    text-decoration: none;
    font-size: 15px;
    font-weight: 600;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-login svg {
    width: 20px;
    height: 20px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-socials {
    display: flex;
    align-items: center;
    gap: 18px;
    margin-top: 12px;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-socials a {
    display: flex;
    color: var(--text-color);
    text-decoration: none;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-socials svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  /* Hamburger changes to X while drawer is open */
  #FreshHeader-{{ section.id }} .fresh-mobile-menu[open] .fresh-menu-toggle .line-1 {
    transform: translateY(6px) rotate(45deg);
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-menu[open] .fresh-menu-toggle .line-2 {
    opacity: 0;
  }

  #FreshHeader-{{ section.id }} .fresh-mobile-menu[open] .fresh-menu-toggle .line-3 {
    transform: translateY(-6px) rotate(-45deg);
  }

  #FreshHeader-{{ section.id }} .fresh-menu-toggle path {
    transform-box: fill-box;
    transform-origin: center;
    transition: transform .25s ease, opacity .25s ease;
  }

  @media (max-width: 1100px) {
    #FreshHeader-{{ section.id }} .fresh-mega-menu {
      padding: 25px;
      gap: 15px;
    }

    #FreshHeader-{{ section.id }} .fresh-product-card {
      height: 320px;
    }

    #FreshHeader-{{ section.id }} .fresh-product-content h3 {
      font-size: 19px;
    }
  }

  @media (max-width: 768px) {
    #FreshHeader-{{ section.id }} .fresh-header {
      min-height: 70px;
      padding: 16px 20px;
    }

    #FreshHeader-{{ section.id }} .fresh-desktop-nav {
      display: none;
    }

    #FreshHeader-{{ section.id }} .fresh-mobile-menu {
      display: block;
    }

    #FreshHeader-{{ section.id }} .fresh-logo {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
    }

    #FreshHeader-{{ section.id }} .fresh-logo-text {
      font-size: 20px;
      white-space: nowrap;
    }

    #FreshHeader-{{ section.id }} .fresh-account {
      display: none;
    }
  }
</style>

<div id="FreshHeader-{{ section.id }}">
  <header class="fresh-header">

    <!-- MOBILE MENU -->
    <details class="fresh-mobile-menu">
      <summary class="fresh-menu-toggle" aria-label="Open menu">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path class="line-1" d="M4 6h16"></path>
          <path class="line-2" d="M4 12h16"></path>
          <path class="line-3" d="M4 18h16"></path>
        </svg>
      </summary>

      <nav class="fresh-mobile-nav">
        {% assign mobile_shop_title = section.settings.mega_menu_trigger | downcase | strip %}

        {% for link in section.settings.menu.links %}
          {% assign mobile_link_title = link.title | downcase | strip %}

          {% if mobile_link_title == mobile_shop_title and section.settings.mega_collection != blank %}
            <!-- SHOP: accordion only, no redirect -->
            <details class="fresh-mobile-shop">
              <summary>
                <span>{{ link.title }}</span>
                <span class="fresh-mobile-plus" aria-hidden="true"></span>
              </summary>

              <div class="fresh-mobile-shop-products">
                {% for product in section.settings.mega_collection.products limit: 4 %}
                  <a href="{{ product.url }}" class="fresh-mobile-product-card">
                    <div class="fresh-mobile-product-image-wrap">
                      {% if product.featured_image != blank %}
                        {{
                          product.featured_image
                          | image_url: width: 500
                          | image_tag:
                            class: 'fresh-mobile-product-image',
                            widths: '180, 280, 400, 500',
                            alt: product.title,
                            loading: 'lazy'
                        }}
                      {% endif %}
                    </div>

                    <span class="fresh-mobile-product-title">{{ product.title }}</span>

                    {% if product.type != blank %}
                      <span class="fresh-mobile-product-subtitle">{{ product.type }}</span>
                    {% endif %}
                  </a>
                {% endfor %}

                <a href="{{ section.settings.mega_collection.url }}" class="fresh-mobile-shop-all">
                  {{ section.settings.shop_all_text }}
                </a>
              </div>
            </details>
          {% else %}
            <a href="{{ link.url }}">{{ link.title }}</a>
          {% endif %}
        {% endfor %}

        <div class="fresh-mobile-bottom">
          {% if shop.customer_accounts_enabled %}
            <a
              href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
              class="fresh-mobile-login"
            >
              <svg viewBox="0 0 24 24">
                <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                <circle cx="12" cy="7" r="4"></circle>
              </svg>
              {% if customer %}Account{% else %}Login{% endif %}
            </a>
          {% endif %}

          <div class="fresh-mobile-socials">
            {% if section.settings.instagram_url != blank %}
              <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" aria-label="Instagram">
                <svg viewBox="0 0 24 24">
                  <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm5 5a5 5 0 1 0 0 10 5 5 0 0 0 0-10zm6.5-.75a1.25 1.25 0 1 0 0 2.5 1.25 1.25 0 0 0 0-2.5z"/>
                </svg>
              </a>
            {% endif %}

            {% if section.settings.facebook_url != blank %}
              <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener" aria-label="Facebook">
                <svg viewBox="0 0 24 24">
                  <path d="M14 8h3V4h-3c-3.3 0-5 2-5 5v3H6v4h3v8h4v-8h3.5l.5-4h-4V9c0-.7.3-1 1-1z"/>
                </svg>
              </a>
            {% endif %}
          </div>
        </div>
      </nav>
    </details>

    <!-- SHOPIFY LOGO -->
    <a href="{{ routes.root_url }}" class="fresh-logo">
      {% if section.settings.logo != blank %}
        {{
          section.settings.logo
          | image_url: width: 600
          | image_tag:
            widths: '100, 200, 300, 400, 600',
            alt: shop.name,
            loading: 'eager'
        }}
      {% else %}
        <h1 class="fresh-logo-text">{{ shop.name }}</h1>
      {% endif %}
    </a>

    <!-- DESKTOP NAVIGATION -->
    <nav class="fresh-desktop-nav">
      {% for link in section.settings.menu.links %}
        {% assign link_title = link.title | downcase | strip %}
        {% assign shop_title = section.settings.mega_menu_trigger | downcase | strip %}

        {% if link_title == shop_title and section.settings.mega_collection != blank %}
          <div class="fresh-mega-item">
            <!-- SHOP: button only, no redirect -->
            <button
              type="button"
              class="fresh-nav-link fresh-shop-trigger"
              aria-haspopup="true"
              aria-expanded="false"
            >
              <span class="fresh-nav-text">{{ link.title }}</span>
              <span class="fresh-nav-text fresh-nav-duplicate">{{ link.title }}</span>
            </button>

            <div class="fresh-mega-menu">
              {% for product in section.settings.mega_collection.products limit: 4 %}
                <a href="{{ product.url }}" class="fresh-product-card">
                  {% if product.featured_image != blank %}
                    {{
                      product.featured_image
                      | image_url: width: 800
                      | image_tag:
                        class: 'fresh-product-image',
                        widths: '300, 500, 700, 800',
                        alt: product.title,
                        loading: 'lazy'
                    }}
                  {% endif %}

                  <div class="fresh-overlay"></div>

                  <div class="fresh-product-content">
                    <div>
                      <h3>{{ product.title }}</h3>
                      <p>
                        {% if product.type != blank %}
                          {{ product.type }}
                        {% else %}
                          Shop Now
                        {% endif %}
                      </p>
                    </div>
                    <span class="fresh-arrow">→</span>
                  </div>
                </a>
              {% endfor %}

              <div class="fresh-mega-footer">
                <a href="{{ section.settings.mega_collection.url }}">
                  {{ section.settings.shop_all_text }}
                </a>
              </div>
            </div>
          </div>
        {% else %}
          <a href="{{ link.url }}" class="fresh-nav-link">
            <span class="fresh-nav-text">{{ link.title }}</span>
            <span class="fresh-nav-text fresh-nav-duplicate">{{ link.title }}</span>
          </a>
        {% endif %}
      {% endfor %}
    </nav>

    <!-- SHOPIFY ICONS -->
    <div class="fresh-icons">
      <a href="{{ routes.search_url }}" class="fresh-icon" aria-label="Search">
        <svg viewBox="0 0 24 24">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>

      {% if shop.customer_accounts_enabled %}
        <a
          href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
          class="fresh-icon fresh-account"
          aria-label="Account"
        >
          <svg viewBox="0 0 24 24">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
            <circle cx="12" cy="7" r="4"></circle>
          </svg>
        </a>
      {% endif %}

      <a href="{{ routes.cart_url }}" class="fresh-icon" aria-label="Cart">
        <svg viewBox="0 0 24 24">
          <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <path d="M16 10a4 4 0 0 1-8 0"></path>
        </svg>
      </a>
    </div>

  </header>
</div>


<script>
  (() => {
    const root = document.getElementById('FreshHeader-{{ section.id }}');
    if (!root) return;

    /* MOBILE MENU SCROLL LOCK
       Menu open: website stays completely fixed.
       Menu close: page returns to the exact same scroll position.
    */
    const mobileMenu = root.querySelector('.fresh-mobile-menu');
    let lockedScrollY = 0;

    function lockPageScroll() {
      lockedScrollY = window.scrollY || window.pageYOffset;

      document.documentElement.style.overflow = 'hidden';
      document.body.style.position = 'fixed';
      document.body.style.top = `-${lockedScrollY}px`;
      document.body.style.left = '0';
      document.body.style.right = '0';
      document.body.style.width = '100%';
      document.body.style.overflow = 'hidden';
    }

    function unlockPageScroll() {
      document.documentElement.style.overflow = '';
      document.body.style.position = '';
      document.body.style.top = '';
      document.body.style.left = '';
      document.body.style.right = '';
      document.body.style.width = '';
      document.body.style.overflow = '';

      window.scrollTo(0, lockedScrollY);
    }

    if (mobileMenu) {
      mobileMenu.addEventListener('toggle', () => {
        if (mobileMenu.open) {
          lockPageScroll();
        } else {
          unlockPageScroll();
        }
      });
    }

    const megaItem = root.querySelector('.fresh-mega-item');
    const shopTrigger = root.querySelector('.fresh-shop-trigger');

    if (megaItem && shopTrigger) {
      shopTrigger.addEventListener('click', (event) => {
        event.preventDefault();
        const isOpen = megaItem.classList.toggle('is-open');
        shopTrigger.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      });

      document.addEventListener('click', (event) => {
        if (!megaItem.contains(event.target)) {
          megaItem.classList.remove('is-open');
          shopTrigger.setAttribute('aria-expanded', 'false');
        }
      });

      megaItem.addEventListener('mouseleave', () => {
        megaItem.classList.remove('is-open');
        shopTrigger.setAttribute('aria-expanded', 'false');
      });
    }
  })();

  
</script>

