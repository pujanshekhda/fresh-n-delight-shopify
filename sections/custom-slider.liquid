<style>
  .moon-slider-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 20px;
  }

  .moon-slider-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 28 / 10;
    min-height: 300px;
    border-radius: 24px;
    overflow: hidden;
    background: #f4f4f4;
  }

  /* ── SLIDES ─────────────────────────────────────────── */
  .moon-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 900ms cubic-bezier(0.76, 0, 0.24, 1);
    z-index: 0;
    pointer-events: none;
  }

  .moon-slide.is-active {
    opacity: 1;
    z-index: 1;
    pointer-events: auto;
  }

  /* ── CLICKABLE SLIDE ───────────────────────────────── */
  .moon-slide__link {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    cursor: pointer;
    z-index: 1;
  }

  /* ── BACKGROUND IMAGE ──────────────────────────────── */
  .moon-slide__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    will-change: transform;
    transform: scale(1.06);
    transition: transform 900ms cubic-bezier(0.76, 0, 0.24, 1);
  }

  .moon-slide.is-active .moon-slide__bg {
    transform: scale(1);
  }

  .moon-slide__bg picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .moon-slide__bg img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── DOTS ──────────────────────────────────────────── */
  .moon-slider-dots {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    display: flex;
    align-items: center;
    gap: 12px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .moon-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #ffffff;
    border: none;
    cursor: pointer;
    padding: 0;
    opacity: 0.6;
    transition: all 0.3s ease;
  }

  .moon-dot.is-active {
    width: 10px;
    height: 10px;
    background: transparent;
    border: 2px solid #ffffff;
    opacity: 1;
  }

  /* ── ARROWS ────────────────────────────────────────── */
  .moon-arrow {
    position: absolute;
    bottom: 24px;
    z-index: 20;
    background: transparent;
    border: none;
    color: #fff;
    width: 48px;
    height: 48px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.22s, opacity 0.22s;
    padding: 0;
    opacity: 0.8;
  }

  .moon-arrow--prev {
    left: 24px;
  }

  .moon-arrow--next {
    right: 24px;
  }

  .moon-arrow:hover {
    opacity: 1;
    transform: scale(1.1);
  }

  .moon-arrow svg {
    width: 32px;
    height: 20px;
    fill: none;
    stroke: #fff;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* ── MOBILE — MOON STYLE ───────────────────────────── */
  @media (max-width: 749px) {
    .moon-slider-container {
      width: 100%;
      max-width: 100%;
      padding: 10px;
      margin: 0 auto;
    }

    .moon-slider-wrap {
      width: 100%;
      aspect-ratio: 3 / 4;
      min-height: 0;
      border-radius: 16px;
      overflow: hidden;
      position: relative;
    }

    .moon-slide__bg {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      transform: none !important;
    }

    .moon-slide__bg picture {
      display: block;
      width: 100%;
      height: 100%;
    }

    .moon-slide__bg img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center center;
    }

    .moon-arrow {
      display: none;
    }

    .moon-slider-dots {
      bottom: 16px;
      gap: 8px;
    }

    .moon-dot {
      width: 6px;
      height: 6px;
    }

    .moon-dot.is-active {
      width: 10px;
      height: 10px;
    }
  }
</style>


<div class="moon-slider-container">

  <div
    class="moon-slider-wrap"
    id="MoonSlider-{{ section.id }}"
    data-autoplay="{{ section.settings.autoplay }}"
    data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
    aria-label="Hero slideshow"
  >

    {%- for block in section.blocks -%}
      {%- if block.type == 'slide' -%}

        {%- assign slide_image = block.settings.image -%}
        {%- assign slide_image_mobile = block.settings.image_mobile -%}

        <div
          class="moon-slide{% if forloop.first %} is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >

          {%- if slide_image != blank -%}

            {%- if block.settings.slide_link != blank -%}
              <a
                href="{{ block.settings.slide_link }}"
                class="moon-slide__link"
                aria-label="View featured collection"
              >
            {%- endif -%}

              <div class="moon-slide__bg">

                <picture>

                  {%- if slide_image_mobile != blank -%}
                    <source
                      media="(max-width: 749px)"
                      srcset="{{ slide_image_mobile | image_url: width: 1600 }}"
                    >
                  {%- endif -%}

                  <img
                    src="{{ slide_image | image_url: width: 3840 }}"
                    alt="{{ slide_image.alt | default: 'Slide Image' | escape }}"
                    width="{{ slide_image.width }}"
                    height="{{ slide_image.height }}"
                    loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                  >

                </picture>

              </div>

            {%- if block.settings.slide_link != blank -%}
              </a>
            {%- endif -%}

          {%- else -%}

            <div
              class="moon-slide__bg"
              style="background-color: #1a1a1a;"
            ></div>

          {%- endif -%}

        </div>

      {%- endif -%}
    {%- endfor -%}


    {%- if section.blocks.size > 1 -%}

      <!-- PREVIOUS ARROW -->
      <button
        class="moon-arrow moon-arrow--prev"
        aria-label="{{ 'general.slider.previous_slide' | t }}"
      >
        <svg viewBox="0 0 37 24">
          <path d="M10 5L3 11.9999M3 11.9999L10 18.9999M3 11.9999H33.5"></path>
        </svg>
      </button>


      <!-- DOTS -->
      <ul
        class="moon-slider-dots"
        role="tablist"
        aria-label="Slideshow pagination"
      >

        {%- for block in section.blocks -%}

          {%- if block.type == 'slide' -%}

            <li role="presentation">

              <button
                class="moon-dot{% if forloop.first %} is-active{% endif %}"
                role="tab"
                aria-label="Slide {{ forloop.index }}"
                data-slide="{{ forloop.index0 }}"
              ></button>

            </li>

          {%- endif -%}

        {%- endfor -%}

      </ul>


      <!-- NEXT ARROW -->
      <button
        class="moon-arrow moon-arrow--next"
        aria-label="{{ 'general.slider.next_slide' | t }}"
      >
        <svg viewBox="0 0 37 24">
          <path d="M26.5 5L33.5 11.9999M33.5 11.9999L26.5 18.9999M33.5 11.9999H3"></path>
        </svg>
      </button>

    {%- endif -%}

  </div>

</div>


<script>
(function () {

  var wrap = document.getElementById(
    'MoonSlider-{{ section.id }}'
  );

  if (!wrap) return;


  var slides = Array.from(
    wrap.querySelectorAll('.moon-slide')
  );

  var dots = Array.from(
    wrap.querySelectorAll('.moon-dot')
  );

  var prevBtn = wrap.querySelector(
    '.moon-arrow--prev'
  );

  var nextBtn = wrap.querySelector(
    '.moon-arrow--next'
  );


  var autoplay =
    wrap.dataset.autoplay === 'true';

  var speed =
    parseInt(wrap.dataset.speed, 10) || 5000;

  var current = 0;

  var timer = null;

  var busy = false;


  function goTo(idx) {

    if (busy || slides.length < 2) return;


    var next =
      ((idx % slides.length) + slides.length)
      % slides.length;


    if (next === current) return;


    busy = true;


    slides[current]
      .classList
      .remove('is-active');


    dots[current] &&
      dots[current]
        .classList
        .remove('is-active');


    current = next;


    slides[current]
      .classList
      .add('is-active');


    dots[current] &&
      dots[current]
        .classList
        .add('is-active');


    setTimeout(function () {

      busy = false;

    }, 950);

  }


  function advance() {

    goTo(current + 1);

  }


  function retreat() {

    goTo(current - 1);

  }


  /* AUTOPLAY */

  function startAuto() {

    if (!autoplay) return;

    clearInterval(timer);

    timer = setInterval(
      advance,
      speed
    );

  }


  function stopAuto() {

    clearInterval(timer);

  }


  /* DOT CLICK */

  dots.forEach(function (dot) {

    dot.addEventListener(
      'click',
      function () {

        stopAuto();

        goTo(
          parseInt(
            dot.dataset.slide,
            10
          )
        );

        startAuto();

      }
    );

  });


  /* ARROWS */

  if (prevBtn) {

    prevBtn.addEventListener(
      'click',
      function () {

        stopAuto();

        retreat();

        startAuto();

      }
    );

  }


  if (nextBtn) {

    nextBtn.addEventListener(
      'click',
      function () {

        stopAuto();

        advance();

        startAuto();

      }
    );

  }


  /* MOBILE SWIPE */

  var touchStartX = 0;

  var touchMoved = false;


  wrap.addEventListener(
    'touchstart',
    function (e) {

      touchStartX =
        e.changedTouches[0].clientX;

      touchMoved = false;

    },
    {
      passive: true
    }
  );


  wrap.addEventListener(
    'touchend',
    function (e) {

      var difference =
        e.changedTouches[0].clientX
        - touchStartX;


      if (Math.abs(difference) > 48) {

        touchMoved = true;

        stopAuto();


        if (difference < 0) {

          advance();

        } else {

          retreat();

        }


        startAuto();

      }

    },
    {
      passive: true
    }
  );


  /* PREVENT LINK OPENING AFTER SWIPE */

  wrap
    .querySelectorAll('.moon-slide__link')
    .forEach(function (link) {

      link.addEventListener(
        'click',
        function (e) {

          if (touchMoved) {

            e.preventDefault();

            touchMoved = false;

          }

        }
      );

    });


  /* HOVER PAUSE */

  wrap.addEventListener(
    'mouseenter',
    stopAuto
  );


  wrap.addEventListener(
    'mouseleave',
    startAuto
  );


  /* KEYBOARD */

  wrap.addEventListener(
    'keydown',
    function (e) {

      if (e.key === 'ArrowLeft') {

        stopAuto();

        retreat();

        startAuto();

      }


      if (e.key === 'ArrowRight') {

        stopAuto();

        advance();

        startAuto();

      }

    }
  );


  /* START */

  if (
    autoplay &&
    slides.length > 1
  ) {

    startAuto();

  }

})();
</script>


{% schema %}
{
  "name": "Moon Hero Slider",
  "tag": "section",
  "class": "moon-hero-slider-section",

  "settings": [

    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-play slides",
      "default": true
    },

    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Seconds per slide",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    }

  ],

  "blocks": [

    {
      "type": "slide",
      "name": "Slide",

      "settings": [

        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (Desktop)"
        },

        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "Image (Mobile) – Optional"
        },

        {
          "type": "url",
          "id": "slide_link",
          "label": "Slide Link"
        }

      ]

    }

  ],

  "presets": [

    {
      "name": "Moon Hero Slider",

      "blocks": [

        {
          "type": "slide"
        },

        {
          "type": "slide"
        },

        {
          "type": "slide"
        }

      ]

    }

  ],

  "enabled_on": {

    "templates": [
      "index"
    ]

  }

}
{% endschema %}